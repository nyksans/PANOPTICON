# ==========================================
# PANOPTICON Docker Environment Variables
# ==========================================
# Copy to docker/.env and update values

# Database
POSTGRES_USER=panopticon
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=panopticon

# Redis
REDIS_PASSWORD=

# Backend
DATABASE_URL=postgresql+asyncpg://panopticon:CHANGE_ME@postgres:5432/panopticon
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# JWT - MUST CHANGE IN PRODUCTION
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET

# Frontend
NEXT_PUBLIC_API_URL=http://your-domain.com
NEXT_PUBLIC_WS_URL=ws://your-domain.com
